{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": ["APP_TARGET"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "cache": true,
      "persistent": false,
      "outputs": ["build"],
      "dependsOn": ["^build"]
    },
    "lint": {
      "cache": true,
      "inputs": ["src/**/*.{ts,tsx,js,jsx}"]
    },
    "type:check": {
      "cache": false,
      "persistent": false
    },
    "clean": {
      "cache": false,
      "persistent": false,
      "outputs": []
    }
  }
}
