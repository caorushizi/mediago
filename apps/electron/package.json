    "typescript": "^6.0.2",
    "cross-env": "^10.1.0",
    "dotenv-flow": "^4.1.0",
    "electron": "41.1.0",
    "electron-builder": "26.8.1",
    "electron-builder-squirrel-windows": "26.8.1",
    "electron-updater": "^6.8.3",
    "glob": "^11.0.3",
    "rimraf": "^6.0.1",
    "rollup-plugin-copy": "^3.5.0",
    "tsdown": "^0.15.9",
    "tsx": "^4.20.6"
  },
  "dependencies": {
